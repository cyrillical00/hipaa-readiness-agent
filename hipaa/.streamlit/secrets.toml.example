# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Used for every Claude call: assessment analysis, roadmap generation,
# validator, fixer, and BAA outreach drafts. Get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = "sk-ant-..."

# ---------------------------------------------------------------------------
# Local-mode authentication
# ---------------------------------------------------------------------------

# Emails allowed past the login gate when running outside Streamlit Cloud.
# On Streamlit Cloud, Google OAuth handles login and this list is ignored.
local_allowed_emails = [
    "cyrillical@gmail.com",
    "demo@hipaa.example",
]

# ---------------------------------------------------------------------------
# Optional GitHub-backed state storage
# ---------------------------------------------------------------------------

# If unset, per-user JSONL state falls back to .streamlit/state on local disk.
# Use a private repo. The PAT needs `repo` scope on that specific repo only,
# nothing else, no org access.
HIPAA_STATE_REPO = ""   # e.g. "cyrillical00/hipaa-state"
HIPAA_STATE_PAT  = ""   # GitHub PAT with repo scope on the state repo above

# ---------------------------------------------------------------------------
# Optional model overrides (defaults shown)
# ---------------------------------------------------------------------------

# Main generator model (assessment, roadmap, BAA drafts).
# CLAUDE_MAIN_MODEL  = "claude-sonnet-4-6"

# Light model used by the validator and fixer in the refine loop.
# CLAUDE_LIGHT_MODEL = "claude-haiku-4-5-20251001"
